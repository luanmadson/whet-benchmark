{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "isolatedModules": false,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": ["src/core/**/*", "src/cli/**/*"],
  "exclude": ["node_modules", ".next"]
}
